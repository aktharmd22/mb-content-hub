APP_NAME="Malayznbeat Content Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=malayzn_content_hub
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# Google Drive (configured in Module 3)
GOOGLE_DRIVE_CREDENTIALS_PATH=storage/app/google-credentials.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_INBOX_FOLDER_ID=
GOOGLE_DRIVE_ASSIGNED_FOLDER_ID=
GOOGLE_DRIVE_INPROGRESS_FOLDER_ID=
GOOGLE_DRIVE_REVIEW_FOLDER_ID=
GOOGLE_DRIVE_CLIENTAPPROVAL_FOLDER_ID=
GOOGLE_DRIVE_REVISIONS_FOLDER_ID=
GOOGLE_DRIVE_APPROVED_FOLDER_ID=
GOOGLE_DRIVE_PUBLISHED_FOLDER_ID=

# Mail — use Mailtrap for dev, Resend for production
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@malayznbeat.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
